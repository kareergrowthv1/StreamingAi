# Server
HOST=0.0.0.0
PORT=9000

# Storage (local dirs; created if missing)
UPLOAD_DIR=./uploads
CHUNKS_DIR=./chunks
MERGED_DIR=./merged

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# DB (optional; for proctoring events)
# DATABASE_URL=postgresql://user:pass@localhost:5432/streaming

# CORS (frontend origin; Vite dev server runs on 5174)
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174
