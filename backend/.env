# Server
HOST=0.0.0.0
PORT=9000

# Storage (local dirs; created if missing)
UPLOAD_DIR=./uploads
CHUNKS_DIR=./chunks
MERGED_DIR=./merged

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0



# CORS (frontend origins)
# 4000 = SuperadminFrontend | 4001 = AdminFrontend | 4002 = CandidateTest | 4003 = CandidateFrontend
CORS_ORIGINS=http://localhost:4000,http://127.0.0.1:4000,http://localhost:4001,http://127.0.0.1:4001,http://localhost:4002,http://127.0.0.1:4002,http://localhost:4003,http://127.0.0.1:4003,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Backend base URLs – used by WebSocket session and AI routes (resume-ats, skills, JD)
ADMIN_BACKEND_URL=http://localhost:8002
CANDIDATE_BACKEND_URL=http://localhost:8003

# Dynamic AI config – fetched from Superadmin (GET /superadmin/settings/ai-config). No hardcoded API keys.
SUPERADMIN_BACKEND_URL=http://localhost:8001
SUPERADMIN_SERVICE_TOKEN=internal_service_secret_token_for_api_gateway
ADMIN_SERVICE_TOKEN=internal_service_secret_token_for_api_gateway

# Optional env fallback if Superadmin fetch fails (e.g. OPENAI_API_KEY, OPENAI_MODEL, OPENAI_BASE_URL)

# MongoDB – report storage (Candidates_Report collection)
MONGODB_URL=mongodb+srv://sharan_db:radhe123@kareergrowth.bmv9oqp.mongodb.net/?appName=KareerGrowth
MONGODB_DB_NAME=kareergrowth

# AssemblyAI (for transcription token)
